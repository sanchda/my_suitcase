#!/usr/bin/env bash
# ralph — global launcher for the Ralph external autonomous loop.
#
# The actual runner lives at $SUITCASE/tools/ralph/ralph.sh. This thin wrapper
# just resolves the suitcase root and execs it, so `ralph` works from any repo
# on your PATH. All driving files (PROMPT.md / VISION / BACKLOG / PROGRESS) are
# LOCAL to whatever repo you run this from — see that repo's tools/ralph/README.
set -euo pipefail

# Resolve SUITCASE: prefer the exported env var, else derive from this script's
# own location (bin/ralph -> repo root), following symlinks.
if [[ -n "${SUITCASE:-}" && -f "$SUITCASE/tools/ralph/ralph.sh" ]]; then
  root="$SUITCASE"
else
  self="${BASH_SOURCE[0]}"
  while [[ -L "$self" ]]; do self="$(readlink "$self")"; done
  root="$(cd "$(dirname "$self")/.." && pwd)"
fi

runner="$root/tools/ralph/ralph.sh"
[[ -f "$runner" ]] || { echo "ralph: runner not found at $runner (is SUITCASE set / installed?)" >&2; exit 3; }
exec bash "$runner" "$@"
